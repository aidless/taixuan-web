{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "taixuan://specs/schools/tarot.result.schema.json",
  "title": "塔罗牌解读结果契约",
  "description": "西方塔罗。结构与 bazi 大体一致,差异在 cards 数组(每张牌一张解读)。",
  "version": "1.0.0",
  "source": "knowledge/20-v2-prompts/tarot.md + tests/liupai-reader-test.js",
  "type": "object",
  "required": ["summary", "spread", "cards", "sections", "disclaimer", "schema_version"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 200
    },
    "spread": {
      "type": "string",
      "enum": ["single_card", "three_card", "celtic_cross"],
      "description": "牌阵类型(对应 cards.length)"
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["position", "name", "orientation"],
        "properties": {
          "position": {
            "type": "string",
            "description": "位置含义,如 'past'、'present'、'future'、或具体牌位名"
          },
          "name": {
            "type": "string",
            "description": "牌名,如 'The Fool'、'愚者'"
          },
          "orientation": {
            "enum": ["upright", "reversed"],
            "description": "正位/逆位"
          },
          "meaning": {
            "type": "string",
            "maxLength": 200,
            "description": "这张牌在此位置的意义"
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["title", "content", "tone"],
        "properties": {
          "title": {"type": "string", "maxLength": 30},
          "content": {"type": "string", "minLength": 30, "maxLength": 500},
          "tone": {"enum": ["neutral", "warm", "cautious"]},
          "keyPoints": {
            "type": "array",
            "maxItems": 5,
            "items": {"type": "string", "maxLength": 50}
          }
        }
      }
    },
    "disclaimer": {
      "type": "string",
      "minLength": 20
    }
  },
  "compliance_constraints": {
    "no_absolute_predictions": "禁用 '必定'、'一定'、'100%'、'必然'",
    "no_fatalism": "禁用 '大凶'、'必死'、'无解'",
    "no_redirection_words": "禁用 '算命'、'占卜'、'预测命运'、'改运'、'法事'(塔罗在国际语境下可保留 'divination' 的中性文化表述,但避免中文红线词)",
    "must_have_disclaimer": "disclaimer 字段不可为空"
  }
}