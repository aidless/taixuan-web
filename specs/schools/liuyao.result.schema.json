{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "taixuan://specs/schools/liuyao.result.schema.json",
  "title": "六爻解读结果契约",
  "description": "8 派结果 schema 之一。六爻以 本卦 + 之卦 + 动爻 + 世应 + 用神为核心。",
  "version": "1.0.0",
  "source": "knowledge/20-v2-prompts/liuyao.md + knowledge/04-liuyao.md + utils/liupai-reader.js",
  "type": "object",
  "required": ["summary", "sections", "disclaimer", "schema_version", "gua"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "summary": {"type": "string", "minLength": 20, "maxLength": 200},
    "gua": {
      "type": "object",
      "description": "卦象",
      "required": ["benGua", "zhiGua", "dongYao"],
      "properties": {
        "benGua": {"type": "string", "description": "本卦名,如 '天水讼'"},
        "zhiGua": {"type": "string", "description": "之卦名,如 '天地否'"},
        "dongYao": {
          "type": "array",
          "items": {"type": "integer", "minimum": 1, "maximum": 6},
          "description": "动爻爻位(1-6)"
        },
        "guaZhi": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "description": "六爻爻辞(从初爻到上爻)",
          "items": {"type": "string"}
        }
      }
    },
    "shiYing": {
      "type": "object",
      "description": "世爻 / 应爻",
      "properties": {
        "shi": {"type": "integer", "minimum": 1, "maximum": 6},
        "ying": {"type": "integer", "minimum": 1, "maximum": 6}
      }
    },
    "yongShen": {"type": "string", "description": "用神天干"},
    "sections": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["title", "content", "tone"],
        "properties": {
          "title": {"type": "string", "maxLength": 30},
          "content": {"type": "string", "minLength": 30, "maxLength": 500},
          "tone": {"enum": ["neutral", "warm", "cautious"]},
          "keyPoints": {"type": "array", "maxItems": 5, "items": {"type": "string", "maxLength": 50}}
        }
      }
    },
    "dayMaster": {"type": "string"},
    "disclaimer": {"type": "string", "minLength": 20}
  },
  "compliance_constraints": {
    "no_absolute_predictions": "禁用 必定 / 一定 / 100% / 必然",
    "no_fatalism": "禁用 大凶 / 必死 / 无解",
    "no_redirection_words": "禁用 算命 / 占卜 / 预测命运 / 改运",
    "must_have_disclaimer": "disclaimer 不可为空"
  }
}