{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "taixuan://specs/schools/western-astro.result.schema.json",
  "title": "西方占星解读结果契约",
  "description": "8 派结果 schema 之一。西占以 本命盘 + 太阳/月亮/上升 + 12 宫位 + 行星相位为核心。",
  "version": "1.0.0",
  "source": "knowledge/20-v2-prompts/western-astro.md + knowledge/07-western-astro.md + utils/liupai-reader.js",
  "type": "object",
  "required": ["summary", "sections", "disclaimer", "schema_version", "natal"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "summary": {"type": "string", "minLength": 20, "maxLength": 200},
    "natal": {
      "type": "object",
      "description": "本命盘(Big Three + 升主)",
      "required": ["sun", "moon", "rising"],
      "properties": {
        "sun": {"type": "string", "description": "太阳星座,如 'Capricorn'"},
        "moon": {"type": "string", "description": "月亮星座"},
        "rising": {"type": "string", "description": "上升星座"},
        "northNode": {"type": "string", "description": "北交点星座"},
        "southNode": {"type": "string", "description": "南交点星座"}
      }
    },
    "planets": {
      "type": "array",
      "description": "主要行星位置",
      "items": {
        "type": "object",
        "required": ["planet", "sign", "house"],
        "properties": {
          "planet": {"enum": ["Sun", "Moon", "Mercury", "Venus", "Mars", "Jupiter", "Saturn", "Uranus", "Neptune", "Pluto"]},
          "sign": {"type": "string", "description": "所在星座"},
          "house": {"type": "integer", "minimum": 1, "maximum": 12},
          "retrograde": {"type": "boolean"}
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["title", "content", "tone"],
        "properties": {
          "title": {"type": "string", "maxLength": 30},
          "content": {"type": "string", "minLength": 30, "maxLength": 500},
          "tone": {"enum": ["neutral", "warm", "cautious"]},
          "keyPoints": {"type": "array", "maxItems": 5, "items": {"type": "string", "maxLength": 50}}
        }
      }
    },
    "dayMaster": {"type": "string", "description": "中文映射日干"},
    "disclaimer": {"type": "string", "minLength": 20}
  },
  "compliance_constraints": {
    "no_absolute_predictions": "禁用 必定 / 一定 / 100% / 必然",
    "no_fatalism": "禁用 大凶 / 必死",
    "no_redirection_words": "禁用 算命 / 占卜 / 预测命运 / 改运",
    "must_have_disclaimer": "disclaimer 不可为空",
    "english_ok": "As above so below / karma / dharma 等英文术语可保留(西方文化语境)"
  }
}